# Kernel config requirements for mlx5 OVS-kernel switchdev offloads per the
# DOCA documentation at
# https://docs.nvidia.com/doca/sdk/ovs-kernel-hardware-acceleration/index.html#src-3818092209_id-.OVSKernelHardwareAccelerationv3.0.0-KernelRequirements
CONFIG_NET_ACT_CSUM=m
CONFIG_NET_ACT_PEDIT=m
CONFIG_NET_ACT_MIRRED=m
CONFIG_NET_ACT_CT=m
CONFIG_NET_ACT_VLAN=m
CONFIG_NET_ACT_GACT=m
CONFIG_NET_CLS_FLOWER=m
CONFIG_NET_CLS_ACT=y
CONFIG_NET_SWITCHDEV=y
CONFIG_NET_TC_SKB_EXT=y
CONFIG_NET_ACT_CT=m
CONFIG_NFT_FLOW_OFFLOAD=m
CONFIG_NET_ACT_TUNNEL_KEY=m
CONFIG_NF_FLOW_TABLE=m
CONFIG_SKB_EXTENSIONS=y
CONFIG_NET_CLS_MATCHALL=m
CONFIG_NET_ACT_POLICE=m
CONFIG_MLX5_ESWITCH=y
